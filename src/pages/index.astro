---
import { getCollection } from "astro:content";

const posts = (await getCollection("insights"))
  .sort((a,b) => b.data.date - a.data.date);

const featured = posts[0];
const rest = posts.slice(1);

function readingTime(text){
  const words = text.split(/\s+/).length;
  return Math.ceil(words / 200);
}
---

<html>
<head>

<title>Perspectives — Patrik Hallén</title>
<link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />

<style>

body{
font-family: system-ui,-apple-system,sans-serif;
max-width:1000px;
margin:auto;
padding:60px 20px;
line-height:1.6;
color:#111;
}

header{
margin-bottom:70px;
}

h1{
font-size:52px;
margin:0;
}

.subtitle{
color:#666;
margin-top:10px;
}

.featured img{
width:100%;
border-radius:12px;
margin-bottom:20px;
}

.featured h2{
font-size:40px;
margin:10px 0;
}

.meta{
font-size:14px;
color:#777;
margin-bottom:12px;
}

.summary{
color:#444;
max-width:700px;
}

.list article{
margin-top:60px;
}

.list img{
width:100%;
border-radius:12px;
margin-bottom:12px;
}

.list h3{
font-size:24px;
margin:0;
}

.tag{
font-size:12px;
letter-spacing:.06em;
text-transform:uppercase;
color:#666;
margin-right:10px;
}

a{
text-decoration:none;
color:inherit;
}

a:hover h2,
a:hover h3{
text-decoration:underline;
}

</style>

</head>

<body>

<header>

<h1>Perspectives</h1>

<p class="subtitle">
Ideas on structure, transformation and execution.
</p>

<p style="color:#777;margin-top:20px;">
Patrik Hallén<br>
Partner at 
<a
href="https://global.andersen.com/consulting"
target="_blank"
rel="noopener"
style="color:#c8102e;font-weight:600;text-decoration:none"
>
Andersen Consulting
</a>
</p>

</header>

<!-- Featured article -->

<section class="featured">

<a href={`/insights/${featured.id}`}>

<img src={`/heroes/${featured.id}.png`} />

<div class="meta">

<span class="tag">{featured.data.topic}</span>

<span>
{new Date(featured.data.date).toLocaleDateString("en-GB")}
</span>

<span> • {readingTime(featured.body)} min read</span>

</div>

<h2>{featured.data.title}</h2>

<p class="summary">
{featured.data.summary}
</p>

</a>

</section>

<!-- Remaining articles -->

<section class="list">

{rest.map(post => (

<article>

<a href={`/insights/${post.id}`}>

<img src={`/heroes/${post.id}.png`} />

<div class="meta">

<span class="tag">{post.data.topic}</span>

<span>
{new Date(post.data.date).toLocaleDateString("en-GB")}
</span>

<span> • {readingTime(post.body)} min read</span>

</div>

<h3>{post.data.title}</h3>

<p class="summary">
{post.data.summary}
</p>

</a>

</article>

))}

</section>

</body>
</html>
